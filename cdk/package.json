{
  "name": "velosim-cdk",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for VeloSim",
  "bin": {
    "velosim-cdk": "bin/velosim.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "synth": "cdk synth",
    "destroy": "cdk destroy",
    "format": "prettier --write app/**/*.{js,jsx,ts,tsx,json,css,md} --no-error-on-unmatched-pattern",
    "format:check": "prettier --check app/**/*.{js,jsx,ts,tsx,json,css,md} --no-error-on-unmatched-pattern",
    "lint": "eslint bin/ lib/",
    "lint:fix": "eslint bin/ lib/ --fix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.150.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "eslint": "^9.36.0",
    "typescript-eslint": "^8.44.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}
