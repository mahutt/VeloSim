#!/bin/bash
# GraphHopper data preparation script for VeloSim
# Generated by Ansible template

set -e

GRAPHHOPPER_DIR="{{ app_dir }}/graphhopper-data"
MONTREAL_URL="https://download.bbbike.org/osm/bbbike/Montreal/Montreal.osm.pbf"
OUTPUT_FILE="montreal-latest.osm.pbf"
MIN_FILE_SIZE=1000000  # 1 MB minimum to catch partial downloads

echo "Setting up GraphHopper data for Montreal..."

mkdir -p "$GRAPHHOPPER_DIR"
cd "$GRAPHHOPPER_DIR"

# Download Montreal data (smaller, focused dataset from BBBike)
if [ ! -f "$OUTPUT_FILE" ]; then
    echo "Downloading Montreal OSM data..."
    wget --timeout=300 --tries=3 -O "$OUTPUT_FILE" "$MONTREAL_URL"

    # Verify the download is not a partial/corrupt file
    ACTUAL_SIZE=$(stat -c%s "$OUTPUT_FILE" 2>/dev/null || stat -f%z "$OUTPUT_FILE" 2>/dev/null || echo 0)
    if [ "$ACTUAL_SIZE" -lt "$MIN_FILE_SIZE" ]; then
        echo "ERROR: Downloaded file is too small (${ACTUAL_SIZE} bytes). Removing partial download."
        rm -f "$OUTPUT_FILE"
        exit 1
    fi
    echo "Download verified: ${ACTUAL_SIZE} bytes."
fi

echo "GraphHopper data preparation completed"
