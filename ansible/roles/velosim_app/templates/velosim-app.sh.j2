#!/bin/bash
# VeloSim Application Management Script
# Generated by Ansible template

set -e

APP_DIR="{{ app_dir }}"
COMPOSE_FILE="$APP_DIR/docker-compose.prod.yml"

cd "$APP_DIR"

case "$1" in
    start)
        echo "Starting VeloSim application..."
        echo "Stopping and removing any existing containers..."
        docker compose -f "$COMPOSE_FILE" down --remove-orphans || true
        echo "Pulling latest images..."
        docker compose -f "$COMPOSE_FILE" pull
        echo "Building application containers..."
        # Force rebuild frontend to pick up environment changes
        docker compose -f "$COMPOSE_FILE" build --no-cache frontend
        docker compose -f "$COMPOSE_FILE" build backend
        echo "Starting containers..."
        docker compose -f "$COMPOSE_FILE" up -d
        echo "Waiting for services to be ready..."
        sleep 10
        docker compose -f "$COMPOSE_FILE" ps
        ;;
    stop)
        echo "Stopping VeloSim application..."
        docker compose -f "$COMPOSE_FILE" down
        ;;
    restart)
        echo "Restarting VeloSim application..."
        docker compose -f "$COMPOSE_FILE" restart
        ;;
    status)
        echo "VeloSim application status:"
        docker compose -f "$COMPOSE_FILE" ps
        ;;
    logs)
        if [ -n "$2" ]; then
            echo "Following logs for $2..."
            docker compose -f "$COMPOSE_FILE" logs -f "$2"
        else
            echo "Following all application logs..."
            docker compose -f "$COMPOSE_FILE" logs -f
        fi
        ;;
    errors)
        echo "=== Recent Application Errors ==="
        echo ""
        echo "Backend container logs (last 50 lines):"
        docker logs --tail 50 velosim-backend 2>&1 | grep -i error || echo "No errors found in backend logs"
        echo ""
        echo "Frontend container logs (last 50 lines):"
        docker logs --tail 50 velosim-frontend 2>&1 | grep -i error || echo "No errors found in frontend logs"
        echo ""
        echo "Nginx error logs (last 20 lines):"
        tail -20 /var/log/nginx/{{ domain_name }}/error.log 2>/dev/null || echo "No nginx error log found"
        echo ""
        echo "Application log files:"
        if [ -f "{{ app_dir }}/logs/error.log" ]; then
            echo "Error log (last 20 lines):"
            tail -20 {{ app_dir }}/logs/error.log
        else
            echo "No application error log found"
        fi
        ;;
    debug)
        echo "=== VeloSim Debug Information ==="
        echo ""
        echo "Container Status:"
        docker compose -f "$COMPOSE_FILE" ps
        echo ""
        echo "Port Status:"
        netstat -tlnp | grep -E ':(3000|8000|5432|5001)' || echo "No application ports listening"
        echo ""
        echo "Backend Health Check:"
        curl -s http://localhost:8000/health || echo "Backend health check failed"
        echo ""
        echo "Database Migration Status:"
        if [ -f "{{ app_dir }}/scripts/migrate-database.sh" ]; then
            echo "Migration script exists ✓"
            echo "JWT Secret file: $([ -f '{{ app_dir }}/.jwt_secret' ] && echo 'exists ✓' || echo 'missing ✗')"
        else
            echo "Migration script missing ✗"
        fi
        echo ""
        echo "Recent Backend Logs (last 10 lines):"
        docker logs --tail 10 velosim-backend
        ;;
    help)
        echo "VeloSim Application Manager"
        echo ""
        echo "Usage: $0 {start|stop|restart|status|logs|errors|debug|update|backup|help}"
        echo ""
        echo "Commands:"
        echo "  start    - Start all VeloSim containers"
        echo "  stop     - Stop all VeloSim containers"
        echo "  restart  - Restart all VeloSim containers"
        echo "  status   - Show container status"
        echo "  logs     - Follow all logs (or specify container: logs backend)"
        echo "  errors   - Show recent errors from all components"
        echo "  debug    - Show comprehensive debug information"
        echo "  update   - Rebuild and restart containers"
        echo "  backup   - Create database backup"
        echo "  help     - Show this help message"
        echo ""
        echo "Examples:"
        echo "  $0 logs backend    # Follow backend logs"
        echo "  $0 errors          # Show recent errors"
        echo "  $0 debug           # Full debug info"
        ;;
    update)
        echo "Updating VeloSim application..."
        echo "Note: Code deployment is managed by Ansible"
        docker compose -f "$COMPOSE_FILE" build --no-cache
        docker compose -f "$COMPOSE_FILE" up -d
        ;;
    backup)
        echo "Creating application backup..."
        $APP_DIR/scripts/backup-database.sh
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|logs|errors|debug|update|backup|help}"
        echo ""
        echo "  start    - Start all services"
        echo "  stop     - Stop all services"
        echo "  restart  - Restart all services"
        echo "  status   - Show service status"
        echo "  logs     - Show logs (optional service name)"
        echo "  errors   - Show recent errors from all components"
        echo "  debug    - Show comprehensive debug information"
        echo "  update   - Pull latest code and rebuild"
        echo "  backup   - Create database backup"
        echo "  help     - Show detailed help with examples"
        exit 1
        ;;
esac
