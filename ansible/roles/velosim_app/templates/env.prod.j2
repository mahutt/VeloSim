# VeloSim Production Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@localhost:5432/{{ postgres_db }}

# OSRM Configuration
OSRM_URL=http://localhost:5001

# Application Configuration
{% if ssl_enabled | default(false) %}
BACKEND_URL=https://{{ domain_name }}
FRONTEND_URL=https://{{ domain_name }}
{% else %}
BACKEND_URL=http://{{ domain_name }}
FRONTEND_URL=http://{{ domain_name }}
{% endif %}
API_BASE_URL=/api

# Frontend Environment Variables (Vite)
VITE_BACKEND_URL=
VITE_MAPBOX_ACCESS_TOKEN={{ mapbox_access_token | default('') }}

# Security
SECRET_KEY={{ vault_secret_key | default('CHANGE_THIS_IN_PRODUCTION') }}
JWT_SECRET={{ vault_jwt_secret | default('CHANGE_THIS_IN_PRODUCTION') }}
VELOSIM_JWT_SECRET={{ velosim_jwt_secret }}

# External Services
{% if mapbox_access_token is defined %}
MAPBOX_ACCESS_TOKEN={{ mapbox_access_token }}
{% endif %}

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/{{ app_name }}/application.log

# Performance
WORKERS=4
MAX_CONNECTIONS=100

# Environment
ENVIRONMENT=production
DEBUG=false
