# VeloSim Production Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@localhost:5432/{{ postgres_db }}

# OSRM Configuration
OSRM_URL=http://localhost:5001

# Application Configuration
{% if ssl_enabled | default(false) %}
BACKEND_URL=https://{{ domain_name }}
FRONTEND_URL=https://{{ domain_name }}
{% else %}
BACKEND_URL=http://{{ domain_name }}
FRONTEND_URL=http://{{ domain_name }}
{% endif %}
API_BASE_URL=/api

# Frontend Environment Variables (Vite)
VITE_BACKEND_URL=
VITE_MAPBOX_ACCESS_TOKEN={{ mapbox_access_token | default('') }}

# Security
# These are auto-generated on first deployment. For production, set these in group_vars or vault.
SECRET_KEY={{ velosim_secret_key | default(lookup('password', '/dev/null chars=ascii_letters,digits length=64'), true) }}
JWT_SECRET={{ velosim_jwt_secret | default(lookup('password', '/dev/null chars=ascii_letters,digits length=64'), true) }}
VELOSIM_JWT_SECRET={{ velosim_jwt_secret | default(lookup('password', '/dev/null chars=ascii_letters,digits length=64'), true) }}

# External Services
{% if mapbox_access_token is defined %}
MAPBOX_ACCESS_TOKEN={{ mapbox_access_token }}
{% endif %}

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/{{ app_name }}/application.log

# Performance
WORKERS=4
MAX_CONNECTIONS=100

# Environment
ENVIRONMENT=production
DEBUG=false
