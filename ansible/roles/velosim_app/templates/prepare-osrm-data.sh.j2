#!/bin/bash
# OSRM Data Preparation Script for VeloSim
# Generated by Ansible template

set -e

OSRM_DIR="{{ app_dir }}/osrm-data"
MONTREAL_URL="https://download.bbbike.org/osm/bbbike/Montreal/Montreal.osm.pbf"
# Use OSRM v6.0.0 without SHA hash to avoid resolution issues
OSRM_IMAGE="ghcr.io/project-osrm/osrm-backend:v6.0.0"

echo "Setting up OSRM data for Montreal..."

cd "$OSRM_DIR"

# Check if Docker is available
if ! command -v docker &> /dev/null; then
    echo "Error: Docker is not available"
    exit 1
fi

# Pull OSRM image if not available
echo "Pulling OSRM Docker image..."
docker pull "$OSRM_IMAGE"

# Download Montreal data (smaller, focused dataset from BBBike)
if [ ! -f "montreal.osm.pbf" ]; then
    echo "Downloading Montreal OSM data..."
    wget -O montreal.osm.pbf "$MONTREAL_URL"
fi

# Process data for OSRM (same as prepare-osrm.js script)
echo "Processing OSRM data..."
docker run --rm -v "$PWD:/data" "$OSRM_IMAGE" \
    osrm-extract -p /opt/car.lua /data/montreal.osm.pbf

docker run --rm -v "$PWD:/data" "$OSRM_IMAGE" \
    osrm-partition /data/montreal.osrm

docker run --rm -v "$PWD:/data" "$OSRM_IMAGE" \
    osrm-customize /data/montreal.osrm

echo "OSRM data preparation completed!"