# VeloSim Production Docker Compose Configuration
# This file is managed by Ansible - do not edit manually

networks:
  velosim-net:
    driver: bridge

volumes:
  postgres_data:
    driver: local
  osrm_data:
    driver: local

services:
  # PostgreSQL Database
  postgres:
    image: postgres:{{ postgres_version }}-alpine
    container_name: velosim-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: {{ postgres_user }}
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_DB: {{ postgres_db }}
    ports:
      - "127.0.0.1:5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - {{ app_dir }}/source/back/database/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
      - {{ app_dir }}/source/back/alembic/seeds/seed.sql:/docker-entrypoint-initdb.d/seed.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - velosim-net
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # OSRM Routing Server
  osrm:
    image: ghcr.io/project-osrm/osrm-backend:v6.0.0
    container_name: velosim-osrm
    restart: unless-stopped
    ports:
      - "127.0.0.1:5001:5000"
    volumes:
      - {{ app_dir }}/osrm-data:/data:ro
    command: osrm-routed --algorithm mld /data/montreal.osrm
    networks:
      - velosim-net
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # Backend API
  backend:
    build:
      context: {{ app_dir }}/source
      dockerfile: back/Dockerfile
    container_name: velosim-backend
    restart: unless-stopped
    ports:
      - "127.0.0.1:8000:8000"
    volumes:
      - {{ app_dir }}/logs:/app/logs
      - {{ app_dir }}/grafana_logging:/app/grafana_logging
      - {{ app_dir }}/.env.prod:/app/.env:ro
    environment:
      - DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@postgres:5432/{{ postgres_db }}
      - OSRM_URL=http://osrm:5000
      - LOG_FILE_PATH=/app/grafana_logging/logs.txt
    env_file:
      - {{ app_dir }}/.env.prod
    depends_on:
      postgres:
        condition: service_healthy
      osrm:
        condition: service_started
    networks:
      - velosim-net
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # Frontend
  frontend:
    build:
      context: {{ app_dir }}/source
      dockerfile: front/Dockerfile
      args:
        - "VITE_BACKEND_URL=https://{{ domain_name }}"
        - "VITE_MAPBOX_ACCESS_TOKEN={{ vite_mapbox_token | default('') }}"
    container_name: velosim-frontend
    restart: unless-stopped
    ports:
      - "127.0.0.1:3000:3000"
    environment:
      - VITE_MAPBOX_ACCESS_TOKEN={{ vite_mapbox_token | default('') }}
    depends_on:
      backend:
        condition: service_healthy
    networks:
      - velosim-net
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # Loki for log aggregation
  loki:
    image: grafana/loki:2.9.0
    container_name: velosim-loki
    restart: unless-stopped
    ports:
      - "127.0.0.1:3100:3100"
    volumes:
      - {{ app_dir }}/loki-config.yaml:/etc/loki/local-config.yaml:ro
      - {{ app_dir }}/loki/chunks:/loki/chunks
      - {{ app_dir }}/loki/index:/loki/index
      - {{ app_dir }}/loki/cache:/loki/cache
      - {{ app_dir }}/loki/wal:/loki/wal
      - {{ app_dir }}/loki/compactor:/loki/compactor
    command: -config.file=/etc/loki/local-config.yaml
    networks:
      - velosim-net
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3100/ready || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # Promtail for log collection
  promtail:
    image: grafana/promtail:2.9.0
    container_name: velosim-promtail
    restart: unless-stopped
    volumes:
      - {{ app_dir }}/promtail-config.yaml:/etc/promtail/promtail-config.yaml:ro
      - {{ app_dir }}/grafana_logging:/logs:ro
      - {{ app_dir }}/promtail/positions:/var/lib/promtail
      - /var/run/docker.sock:/var/run/docker.sock:ro
    command: -config.file=/etc/promtail/promtail-config.yaml
    depends_on:
      loki:
        condition: service_healthy
    networks:
      - velosim-net
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  # Grafana for monitoring (optional)
  # Access via SSH tunnel only: ssh -L 3001:localhost:3001 user@server
  grafana:
    image: grafana/grafana:11.0.0
    container_name: velosim-grafana
    restart: unless-stopped
    ports:
      - "127.0.0.1:3001:3000"
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_password | default('admin') }}
    volumes:
      - {{ app_dir }}/source/grafana_logging/grafana/provisioning:/etc/grafana/provisioning:ro
    depends_on:
      loki:
        condition: service_healthy
    networks:
      - velosim-net
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
