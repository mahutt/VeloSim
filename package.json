{
    "name": "velosim",
    "version": "1.0.0",
    "description": "VeloSim monorepo workspace scripts",
    "scripts": {
        "test": "python -m pytest",
        "test:coverage": "coverage run --source=back,sim -m pytest && coverage report && coverage html",
        "test:coverage-check": "coverage run --source=back,sim -m pytest && coverage report --fail-under=70",
        "lint": "flake8 back sim && black --check back sim && mypy back sim",
        "lint:fix": "black back sim",
        "format": "npm run lint:fix",
        "validate:init": "python scripts/validate_init_files.py",
        "validate:licenses": "python scripts/validate_license_headers.py",
        "validate:branch": "python scripts/validate_branch_name.py",
        "validate": "npm run validate:init && npm run validate:licenses && npm run validate:branch",
        "setup": "pip install -e .[dev] && pre-commit install && cd front && npm install && cd ..",
        "clean": "rimraf coverage_html/ .pytest_cache/ .mypy_cache/ front/coverage/ front/node_modules/",
        "ci:test": "npm run lint && npm run test:coverage",
        "dev:backend": "cd back && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
        "dev:db": "docker-compose up -d postgres",
        "dev:db-stop": "docker-compose down",
        "dev:full": "docker-compose up -d postgres && python -m uvicorn back.main:app --reload",
        "db:current": "node scripts/db-migrate.js current",
        "db:status": "node scripts/db-migrate.js status",
        "db:generate": "node scripts/db-migrate.js generate",
        "db:upgrade": "node scripts/db-migrate.js upgrade",
        "db:downgrade": "node scripts/db-migrate.js downgrade",
        "db:history": "node scripts/db-migrate.js history",
        "db:seed": "node scripts/db-migrate.js seed",
        "db:migrate": "npm run db:upgrade",
        "db:migrate:create": "npm run db:generate",
        "db:migrate:undo": "npm run db:downgrade",
        "db:migrate:status": "npm run db:current",
        "db:migrate:history": "npm run db:history"
    },
    "devDependencies": {
        "concurrently": "^8.2.0",
        "rimraf": "^5.0.0"
    }
}
