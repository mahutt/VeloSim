      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(process_cpu_seconds_total{job=\"velosim-backend\"}[1m]) * 100",
          "legendFormat": "Backend CPU %",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Python Backend CPU Usage (%)",
      "type": "timeseries"
    },
